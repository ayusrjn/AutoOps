# AutoOps Environment Configuration Template
# Copy this file to '.env' and fill in your actual credentials/endpoints.

# LiteLLM/Gemini API key (Required for root cause analysis)
GEMINI_API_KEY=your_gemini_api_key_here

# LLM model registry target (Defaults to gemini-2.5-flash)
LITELLM_MODEL=gemini/gemini-2.5-flash

# Telemetry Endpoint Configurations
# Use 'host.docker.internal' to reference services hosted on the host machine.
PROMETHEUS_URL=http://host.docker.internal:9090
LOKI_URL=http://host.docker.internal:3100
JAEGER_URL=http://host.docker.internal:16686
